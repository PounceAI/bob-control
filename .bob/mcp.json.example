{
  "$schema": "https://bob-code.com/schemas/mcp-config.schema.json",
  "mcpServers": {
    "bob-tasks": {
      "type": "stdio",
      "command": "node",
      "args": ["/absolute/path/to/bob-control/dist/server.js"],
      "env": {
        "BOB_TASKS_PORTABLE": "1"
      },
      "cwd": "/absolute/path/to/bob-control",
      "timeout": 60,
      "disabled": false,
      "alwaysAllow": [
        "list_tasks",
        "get_task",
        "get_next_task",
        "claim_task",
        "update_task_status",
        "add_task_note",
        "submit_result",
        "create_task",
        "set_task_mode",
        "set_task_dependencies",
        "delete_task",
        "board_status",
        "record_artifact",
        "release_tasks",
        "arm_board",
        "disarm_board"
      ],
      "watchPaths": ["/absolute/path/to/bob-control/dist/server.js"]
    }
  }
}
