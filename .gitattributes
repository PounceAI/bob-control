# Normalize line endings: LF in the repo, native on checkout.
# Keeps the tree consistent across WSL (Linux) and Windows.
* text=auto eol=lf

# Windows-only scripts must stay CRLF to run correctly.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never touch.
*.png binary
*.vsix binary
*.ico binary
