# Dependencies
node_modules/
extension/node_modules/

# Build output (regenerated via `npm run build` / `tsc`)
dist/
extension/out/

# Plugin server bundle (regenerated via `npm run build:plugin`)
claude-plugin/server/

# Packaged extension artifact (produced by `vsce package`)
extension/*.vsix

# Runtime data (SQLite task/audit DBs)
data/

# Logs
*.log

# Backups
*.bak
*.bak2

# Claude Code local (machine-specific) settings
.claude/settings.local.json

# Editor (machine-specific) settings
.vscode/

# Live Bob MCP config holds absolute machine paths; ship .example instead
.bob/mcp.json

# Planning / design notes, not part of the shipped project
docs/

# Scratch: local dev/verification harnesses, not part of the shipped project
scratch/

# OS / editor cruft
.DS_Store
Thumbs.db
test-deps.db
# SQLite WAL/SHM sidecars (transient; created by test/board runs)
*.db-shm
*.db-wal
*.db-journal
